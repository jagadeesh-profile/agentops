{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Dev Server",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["orchestrator.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--app-dir", "src"],
      "port": 8000
    },
    {
      "name": "Docker Compose",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 8000
    },
    {
      "name": "Legacy API Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["api/main.py"],
      "port": 8000
    }
  ]
}
